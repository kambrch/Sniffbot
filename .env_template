# MQTT broker (hostname only, no mqtt:// prefix)
MQTT_BROKER=router-hswro
MQTT_PORT=1883
MQTT_USERNAME=<mqtt-username>
MQTT_PASSWORD=<your-mqtt-password>

MQTT_TOPIC=tele/tasmota_F847F7/SENSOR

TELEGRAM_TOKEN=<token-from-BotFather>

# Comma-separated Telegram chat IDs allowed to query the bot (empty = allow all)
TELEGRAM_ALLOWED_IDS=

LOG_RETENTION_DAYS=30

# Log directory (default: logs/ relative to working directory at startup)
# Override when using a sysimage, which bakes the build-time path otherwise.
#SNIFFBOT_LOG_DIR=/opt/sniffbot/logs
